# SF4 host configuration — copy to .env and fill in.
#   cp .env.example .env   (or: make env)

# LLM provider for the tone engine. OpenAI is the default when OPENAI_API_KEY is set.
SF4_LLM_PROVIDER=openai
OPENAI_CHAT_MODEL=gpt-5.5

# Optional fallback if using SF4_LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
SF4_MODEL=claude-haiku-4-5

# Force a serial port (e.g. /dev/tty.usbmodem1101). Leave blank to auto-detect;
# falls back to a mock board when no Arduino is found.
SF4_PORT=

# Required for voice input (STT via Whisper).
# For the ARM enterprise proxy, set:
#   OPENAI_BASE_URL=https://openai-api-proxy.geo.arm.com/api/providers/openai/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Use this on Arm machines if Python cannot verify the enterprise proxy certificate.
OPENAI_CA_BUNDLE=/usr/local/share/ca-certificates/ARM-Enterprise-PKI-Root-CA.crt
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Web server bind address / port (used by the Makefile).
HOST=127.0.0.1
PORT=8000
